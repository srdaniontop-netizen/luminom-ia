# ==============================================
# LUMINOM IA - CONFIGURACIÓN DE ENTORNO
# ==============================================

# Puerto del servidor
PORT=5000

# Base de datos MongoDB
# Opción 1: MongoDB Local
MONGODB_URI=mongodb://localhost:27017/luminom-ia

# Opción 2: MongoDB Atlas (Cloud - Recomendado)
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/luminom-ia?retryWrites=true&w=majority

# JWT Secret (Genera uno seguro único para producción)
# Puedes generar uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_clave_secreta_super_segura_cambiala_en_produccion_12345

# API Key de Anthropic Claude
# Obtén tu clave en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-tu-clave-aqui

# Configuración del administrador por defecto
ADMIN_EMAIL=admin@luminom.ia
ADMIN_PASSWORD=Admin2026Luminom!

# Entorno (development, production)
NODE_ENV=development

# CORS - Dominio del frontend (en producción)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
